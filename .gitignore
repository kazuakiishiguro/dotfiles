emacs/.emacs.d/**
!emacs/.emacs.d/init.el
!emacs/.emacs.d/custom.el
!emacs/.emacs.d/*.org
bin/.bin/rust-analyzer
git/.gitconfig_work
*.lock.json
.agent-shell
*.bak*

# Ignore everything under config/.config except tracked files.
# With --no-folding, stow creates real dirs — untracked app data must not leak in.
config/.config/**
!config/.config/ghostty/
!config/.config/ghostty/config
!config/.config/github-copilot/
!config/.config/github-copilot/versions.json
!config/.config/hypr/
