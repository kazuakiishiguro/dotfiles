!config/.config/hypr/bindings.conf
!config/.config/hypr/clamshell.conf
!config/.config/hypr/hypridle.conf
!config/.config/hypr/hyprland.conf
!config/.config/hypr/hyprlock.conf
!config/.config/hypr/hyprsunset.conf
!config/.config/hypr/input.conf
!config/.config/hypr/looknfeel.conf
!config/.config/hypr/monitors.conf
!config/.config/hypr/envs.conf
!config/.config/hypr/xdph.conf
!config/.config/i3/
!config/.config/i3/config
!config/.config/kitty/
!config/.config/kitty/kitty.conf
!config/.config/rofi/
!config/.config/rofi/config.rasi
!config/.config/rofi/slate.rasi
!config/.config/fcitx5/
!config/.config/fcitx5/config
!config/.config/fcitx5/profile
